# ============================================================================
# Libya PMM Automation - Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to Git!
# ============================================================================

# --- MoDa API ---
# Your personal MoDa API token (each team member has their own)
MODA_TOKEN=your_moda_api_token_here

# Optional: Path to a separate .env file containing MODA_TOKEN
# MODA_ENV_PATH=/path/to/your/moda_api.env

# --- Database ---
DB_HOST=set_db_host_here
DB_PORT=set_db_port_here
DB_NAME=set_db_name_here
DB_USER=set_db_user_here
DB_PASSWORD=change_me_to_a_secure_password

# --- pgAdmin ---
PGADMIN_DEFAULT_EMAIL=your.email@example.org
PGADMIN_DEFAULT_PASSWORD=change_me_to_a_secure_password

# --- Data Paths (required for local development) ---
# Set these to your local OneDrive sync folders or wherever your data lives.
# Inside Docker these are mapped via volumes in docker-compose.yml.
MONTHLY_REPORTS_ROOT=/path/to/your/Monthly Reports
DATABRIDGES_BASE=/path/to/your/DataBridges
MASTER_DATA_BASE=/path/to/your/Master Data
