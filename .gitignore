# ============================================================================
# Libya PMM Automation - Git Ignore
# ============================================================================

# Python compiled files
__pycache__/
*.py[cod]
*.pyc
*.pyo
*$py.class
*.so
.Python
*.egg
*.egg-info/
dist/
build/
*.whl

# Virtual environments
venv/
env/
ENV/
.venv/

# IDE and editors
.vscode/
.idea/
*.swp
*.swo
*~
.spyderproject
.spyproject

# Operating System
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb

# Environment variables
.env
.env.local

# Logs
*.log
logs/

# Temporary files
tmp/
temp/
*.tmp
*.bak

# Project outputs (generated files - don't commit large Excel files)
outputs/Master Data/*.xlsx
outputs/Exchange Rate/*.xlsx
outputs/DataBridges/*.xlsx

# Database
*.db
*.sqlite
*.sqlite3
*.dump
*.backup
*.sql

# Symlinks to OneDrive (user-specific)
masterdata_pmm

# Generated documentation
README.html
README_files/

# Backups
backups/

# Fonts (redistributable separately)
fonts/

# Coverage reports
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# pytest
.pytest_cache/

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Keep empty directories
!.gitkeep